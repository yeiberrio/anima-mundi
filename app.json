{
  "expo": {
    "name": "Anima Mundi",
    "slug": "anima-mundi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "anima-mundi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A2F6E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.animamundi.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#4A2F6E"
      },
      "package": "com.animamundi.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#4A2F6E"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
